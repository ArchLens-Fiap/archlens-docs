# ========================================
# 🔒 SECRETS ACADÊMICOS - FIAP 12SOAT 2026
# ========================================
# ⚠️ IMPORTANTE: Este arquivo é para uso acadêmico
# ========================================

# ========================================
# 🐳 COMO USAR
# ========================================
# 1. Suba a infra com: cd archlens-infra-db && docker compose up -d
# 2. Execute cada serviço com ASPNETCORE_ENVIRONMENT=Development (local)
#    ou ASPNETCORE_ENVIRONMENT=Docker (via docker-compose)
# 3. As credenciais abaixo são as usadas nos ambientes de dev/Docker
# ========================================

# ╔════════════════════════════════════════════════════════════════╗
# ║                    🏠 AMBIENTE LOCAL (Development)             ║
# ╚════════════════════════════════════════════════════════════════╝

# ========================================
# 1. POSTGRESQL LOCAL (Docker)
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=archlens
POSTGRES_PASSWORD=archlens_dev_2026

# Connection Strings - Local
AUTH_SERVICE_CONNECTION_STRING=Host=localhost;Port=5432;Database=archlens_auth;Username=archlens;Password=archlens_dev_2026
UPLOAD_SERVICE_CONNECTION_STRING=Host=localhost;Port=5432;Database=archlens_upload;Username=archlens;Password=archlens_dev_2026
ORCHESTRATOR_SERVICE_CONNECTION_STRING=Host=localhost;Port=5432;Database=archlens_orchestrator;Username=archlens;Password=archlens_dev_2026

# ========================================
# 2. MONGODB LOCAL (Docker)
# ========================================
MONGODB_CONNECTION_STRING=mongodb://archlens:archlens_dev_2026@localhost:27017
MONGODB_DATABASE_NAME=archlens_reports

# ========================================
# 3. REDIS LOCAL (Docker)
# ========================================
REDIS_CONNECTION_STRING=localhost:6379,password=archlens_dev_2026

# ========================================
# 4. RABBITMQ LOCAL (Docker)
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=archlens
RABBITMQ_PASSWORD=archlens_dev_2026
RABBITMQ_MANAGEMENT_PORT=15672

# ========================================
# 5. MINIO LOCAL (Docker)
# ========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=archlens
MINIO_SECRET_KEY=archlens_dev_2026
MINIO_BUCKET=archlens-diagrams
MINIO_CONSOLE_PORT=9001

# ========================================
# 6. JWT (todos os serviços)
# ========================================
JWT_KEY=archlens-dev-jwt-secret-key-minimum-32-characters!
JWT_ISSUER=archlens-auth
JWT_AUDIENCE=archlens-services
JWT_EXPIRATION_MINUTES=60

# ========================================
# 7. PORTAS DOS SERVIÇOS
# ========================================
AUTH_SERVICE_PORT=5120
UPLOAD_SERVICE_PORT=5066
ORCHESTRATOR_SERVICE_PORT=5089
REPORT_SERVICE_PORT=5205
NOTIFICATION_SERVICE_PORT=5150
GATEWAY_PORT=5080
FRONTEND_PORT=3000
AI_SERVICE_PORT=8000

# ========================================
# 8. URLS DOS SERVIÇOS (Local)
# ========================================
AUTH_SERVICE_URL=http://localhost:5120
UPLOAD_SERVICE_URL=http://localhost:5066
ORCHESTRATOR_SERVICE_URL=http://localhost:5089
REPORT_SERVICE_URL=http://localhost:5205
NOTIFICATION_SERVICE_URL=http://localhost:5150
GATEWAY_URL=http://localhost:5080
FRONTEND_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000

# ╔════════════════════════════════════════════════════════════════╗
# ║                    ☁️ AMBIENTE CLOUD (Gratuito)                ║
# ╚════════════════════════════════════════════════════════════════╝

# ========================================
# 9. NEON POSTGRESQL (Cloud)
# ========================================
# Projeto: archlens
# Região: aws-sa-east-1 (São Paulo)
# Databases: archlens_auth, archlens_upload, archlens_orchestrator
# Console: https://console.neon.tech
# ========================================
NEON_HOST=your-neon-host.neon.tech
NEON_PORT=5432
NEON_USER=neondb_owner
NEON_PASSWORD=your-neon-password

# Connection Strings - Neon
AUTH_SERVICE_CONNECTION_STRING_CLOUD=Host=your-neon-host.neon.tech;Port=5432;Database=archlens_auth;Username=neondb_owner;Password=your-neon-password;SSL Mode=Require
UPLOAD_SERVICE_CONNECTION_STRING_CLOUD=Host=your-neon-host.neon.tech;Port=5432;Database=archlens_upload;Username=neondb_owner;Password=your-neon-password;SSL Mode=Require
ORCHESTRATOR_SERVICE_CONNECTION_STRING_CLOUD=Host=your-neon-host.neon.tech;Port=5432;Database=archlens_orchestrator;Username=neondb_owner;Password=your-neon-password;SSL Mode=Require

# ========================================
# 10. MONGODB ATLAS (Cloud)
# ========================================
# Cluster: archlens
# Região: São Paulo (sa-east-1)
# Database: archlens_reports
# Console: https://cloud.mongodb.com
# ========================================
MONGODB_ATLAS_HOST=archlens.xxxxxxx.mongodb.net
MONGODB_ATLAS_USER=your-atlas-user
MONGODB_ATLAS_PASSWORD=your-atlas-password

# Connection String - MongoDB Atlas
MONGODB_ATLAS_CONNECTION_STRING=mongodb+srv://your-atlas-user:your-atlas-password@archlens.xxxxxxx.mongodb.net/archlens_reports?retryWrites=true&w=majority&appName=archlens

# ========================================
# 11. UPSTASH REDIS (Cloud)
# ========================================
# Database: archlens-notifications
# Região: São Paulo (sa-east-1)
# Console: https://console.upstash.com
# ========================================
UPSTASH_REDIS_HOST=your-upstash-host.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_REST_URL=https://your-upstash-host.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Connection String - Upstash Redis (formato StackExchange.Redis)
UPSTASH_REDIS_CONNECTION_STRING=your-upstash-host.upstash.io:6379,password=your-upstash-token,ssl=True,abortConnect=False

# ========================================
# 12. USUÁRIOS DE DEMO (criados via seed-demo-data.sh)
# ========================================
DEMO_ADMIN_EMAIL=admin@archlens.com
DEMO_ADMIN_PASSWORD=Admin@2026!

DEMO_PROFESSOR_EMAIL=professor@archlens.com
DEMO_PROFESSOR_PASSWORD=Professor@2026!

DEMO_USER_EMAIL=demo@archlens.com
DEMO_USER_PASSWORD=Demo@2026!

# ========================================
# 10. AI PROVIDERS (necessário para análise de diagramas)
# ========================================
# Preencha ao menos uma das chaves abaixo para usar o serviço de IA:
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=your-google-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ╔════════════════════════════════════════════════════════════════╗
# ║                    📊 RESUMO DAS CONEXÕES                      ║
# ╚════════════════════════════════════════════════════════════════╝
#
# | Serviço              | Local               | Cloud                  |
# |----------------------|---------------------|------------------------|
# | Auth Service         | PostgreSQL :5432    | Neon PostgreSQL        |
# | Upload Service       | PostgreSQL :5432    | Neon PostgreSQL        |
# | Orchestrator Service | PostgreSQL :5432    | Neon PostgreSQL        |
# | Report Service       | MongoDB :27017      | MongoDB Atlas          |
# | Notification Service | Redis :6379         | Upstash Redis          |
# | Gateway              | -                   | -                      |
# | AI Processing        | -                   | -                      |
#
# ========================================

