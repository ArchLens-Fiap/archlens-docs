    {
      "name": "Fluxo Completo (Demo)",
      "description": "Execute na ordem para testar o fluxo end-to-end:\n1. Login\n2. Upload\n3. Aguardar processamento (~30s)\n4. Consultar saga\n5. Consultar relatorio\n6. Chat follow-up",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set('auth_token', json.token);",
                  "pm.test('Login successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(json.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"User@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["auth", "login"]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "2. Upload Diagram",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.environment.set('diagram_id', json.diagramId);",
                  "pm.test('Upload successful', function() {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Selecione um diagrama de arquitetura"
                }
              ]
            },
            "url": {
              "raw": "{{gateway_url}}/api/upload/diagrams",
              "host": ["{{gateway_url}}"],
              "path": ["api", "upload", "diagrams"]
            }
          }
        },
        {
          "name": "3. Check Saga Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.analysisId) pm.environment.set('analysis_id', json.analysisId);",
                  "pm.test('Saga found', function() {",
                  "    pm.response.to.have.status(200);",
                  "    console.log('State: ' + json.currentState);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/orchestrator/saga/diagram/{{diagram_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "orchestrator", "saga", "diagram", "{{diagram_id}}"]
            }
          }
        },
        {
          "name": "4. Get Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.environment.set('report_id', json.id);",
                  "pm.test('Report found', function() {",
                  "    pm.response.to.have.status(200);",
                  "    console.log('Score: ' + json.overallScore);",
                  "    console.log('Confidence: ' + json.confidence);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/reports/reports/analysis/{{analysis_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "reports", "reports", "analysis", "{{analysis_id}}"]
            }
          }
        },
        {
          "name": "5. Chat Follow-up",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Chat response received', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"analysis_id\": \"{{analysis_id}}\",\n  \"question\": \"Quais sao os principais riscos dessa arquitetura e como mitiga-los?\",\n  \"history\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/api/ai/chat",
              "host": ["{{gateway_url}}"],
              "path": ["api", "ai", "chat"]
            }
          }
        }
      ]
    }
  ]
}
