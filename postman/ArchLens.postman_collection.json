{
  "info": {
    "name": "ArchLens - API Collection",
    "description": "Collection completa da API ArchLens.\n\n## Como usar\n\n1. Importe o environment `ArchLens - Local`\n2. Execute `Auth > Login (user)` para obter o token automaticamente\n3. Execute `Auth > Login (admin)` para obter o token admin\n4. Todas as requests autenticadas usam `{{auth_token}}` automaticamente\n\n## Usuarios de teste\n- **User**: user / User@123\n- **Admin**: admin / Admin@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "Auth Service",
      "description": "Autenticacao, registro e LGPD (direitos do titular)",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test@123456\",\n  \"lgpdConsent\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/auth/register",
              "host": ["{{gateway_url}}"],
              "path": ["auth", "register"]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Login (user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.environment.set('auth_token', json.token);",
                  "    console.log('Token saved to auth_token');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"User@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["auth", "login"]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.environment.set('admin_token', json.token);",
                  "    pm.environment.set('auth_token', json.token);",
                  "    console.log('Admin token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["auth", "login"]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get My Data (LGPD Art. 18)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/auth/me/data",
              "host": ["{{gateway_url}}"],
              "path": ["auth", "me", "data"]
            }
          }
        },
        {
          "name": "Delete My Account (LGPD Art. 18)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/auth/me",
              "host": ["{{gateway_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Upload Service",
      "description": "Upload de diagramas e consulta de status",
      "item": [
        {
          "name": "Upload Diagram (PNG)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.diagramId) {",
                  "    pm.environment.set('diagram_id', json.diagramId);",
                  "    console.log('diagram_id saved: ' + json.diagramId);",
                  "}",
                  "if (json.isDuplicate) {",
                  "    console.log('DUPLICATE detected - existing diagram returned');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Selecione um diagrama (PNG, JPG, PDF, SVG - max 20MB)"
                }
              ]
            },
            "url": {
              "raw": "{{gateway_url}}/api/upload/diagrams",
              "host": ["{{gateway_url}}"],
              "path": ["api", "upload", "diagrams"]
            }
          }
        },
        {
          "name": "List My Diagrams",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/upload/diagrams?page=1&pageSize=20",
              "host": ["{{gateway_url}}"],
              "path": ["api", "upload", "diagrams"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Diagram by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/upload/diagrams/{{diagram_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "upload", "diagrams", "{{diagram_id}}"]
            }
          }
        },
        {
          "name": "Get Diagram Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/upload/diagrams/{{diagram_id}}/status",
              "host": ["{{gateway_url}}"],
              "path": ["api", "upload", "diagrams", "{{diagram_id}}", "status"]
            }
          }
        },
        {
          "name": "Delete Diagram",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/upload/diagrams/{{diagram_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "upload", "diagrams", "{{diagram_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Orchestrator Service",
      "description": "Consulta de sagas e metricas de processamento",
      "item": [
        {
          "name": "Get Saga by Diagram",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
