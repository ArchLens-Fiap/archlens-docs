                  "    pm.environment.set('analysis_id', json.analysisId);",
                  "    console.log('analysis_id saved: ' + json.analysisId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/orchestrator/saga/diagram/{{diagram_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "orchestrator", "saga", "diagram", "{{diagram_id}}"]
            }
          }
        },
        {
          "name": "Get Saga by Analysis",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/orchestrator/saga/analysis/{{analysis_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "orchestrator", "saga", "analysis", "{{analysis_id}}"]
            }
          }
        },
        {
          "name": "List All Sagas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/orchestrator/saga?page=1&pageSize=20",
              "host": ["{{gateway_url}}"],
              "path": ["api", "orchestrator", "saga"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Admin - Get Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/orchestrator/saga/admin/metrics",
              "host": ["{{gateway_url}}"],
              "path": ["api", "orchestrator", "saga", "admin", "metrics"]
            },
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{admin_token}}" }]
            }
          }
        }
      ]
    },
    {
